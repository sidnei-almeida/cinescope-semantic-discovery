# Opcional — o app já usa a API TMDb do CineScope por padrão.
# Só preencha se quiser sobrescrever localmente.

# Semantic recommender
# Dev (npm run dev): deixe vazio — o app usa proxy /recommender (sem CORS no browser)
# Produção (build): URL completa do Render
# https://tmdb-semantic-recommender.onrender.com
VITE_RECOMMENDER_API_URL=
# Forçar chamada direta ao Render no dev (pode dar CORS/timeout no cold start):
# VITE_RECOMMENDER_DIRECT=true
VITE_TMDB_API_KEY=
VITE_TMDB_READ_TOKEN=
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
