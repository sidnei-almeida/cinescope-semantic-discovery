# Opcional — o app já usa a API TMDb do CineScope por padrão.
# Só preencha se quiser sobrescrever localmente.

# Recommender SEMÂNTICO no Render (tmdb-semantic-recommender) — NÃO remova do deploy.
# Deixe vazio: o app chama /recommender e o Vercel/Vite REPASSA para o Render (modelo intacto).
# Só não coloque a URL do Render no Vercel como env do browser (CORS). O proxy ≠ tirar o modelo.
VITE_RECOMMENDER_API_URL=
# Só se a API tiver CORS liberado para o seu domínio:
# VITE_RECOMMENDER_DIRECT=true
# VITE_RECOMMENDER_API_URL=https://tmdb-semantic-recommender.onrender.com
VITE_TMDB_API_KEY=
VITE_TMDB_READ_TOKEN=
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
